    {
      "name": "Update new booking",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const newRandom = Math.random().toString(32).substring(2);\r",
              "pm.environment.set(\"firstname\", \"Vivek\" + newRandom);\r",
              "pm.environment.set(\"lastname\", \"Badmosh\" + newRandom);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "})\r",
              "\r",
              "const responseJSON = pm.response.json();\r",
              "\r",
              "pm.test(\"Verify First Name is Updated \", function () {\r",
              "    pm.expect(responseJSON.firstname).to.eql(pm.environment.get(\"firstname\"));\r",
              "})\r",
              "\r",
              "pm.test(\"Verify First Name is Updated \", function () {\r",
              "    pm.expect(responseJSON.lastname).to.eql(pm.environment.get(\"lastname\"));\r",
              "})"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
